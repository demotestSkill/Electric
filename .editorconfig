root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{qet,xlsx,pdf,dwg,png,jpg,dxf}]
charset = unset
end_of_line = unset
indent_style = unset
insert_final_newline = false
trim_trailing_whitespace = false
